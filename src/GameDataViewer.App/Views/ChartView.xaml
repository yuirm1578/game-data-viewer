<UserControl
    x:Class="GameDataViewer.App.Views.ChartView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:oxy="http://oxyplot.org/wpf"
    xmlns:vm="clr-namespace:GameDataViewer.App.ViewModels"
    mc:Ignorable="d"
    d:DataContext="{d:DesignInstance Type=vm:ChartViewModel}">

    <UserControl.Resources>
        <!-- 차트 카드 스타일 -->
        <Style x:Key="ChartCard" TargetType="Border">
            <Setter Property="Background"       Value="#1A1A2E"/>
            <Setter Property="BorderBrush"      Value="#2A2A4E"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="CornerRadius"     Value="4"/>
            <Setter Property="Padding"          Value="4"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 헤더: 상태 메시지 + 새로고침 버튼 -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="12,8">
            <TextBlock Text="📊 통계 차트"
                       FontSize="16" FontWeight="SemiBold"
                       Foreground="{DynamicResource MahApps.Brushes.Accent}"
                       VerticalAlignment="Center"/>
            <TextBlock Text="{Binding StatusMessage}"
                       Margin="16,0,0,0"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource MahApps.Brushes.Text}"/>
        </StackPanel>

        <!-- 차트 그리드 (2×2) -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Grid Margin="12,0,12,12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="300"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="380"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- 아이템 등급 파이차트 -->
                <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource ChartCard}">
                    <oxy:PlotView Model="{Binding ItemGradeModel}"
                                  Background="Transparent"/>
                </Border>

                <!-- 몬스터 등급 파이차트 -->
                <Border Grid.Row="0" Grid.Column="2" Style="{StaticResource ChartCard}">
                    <oxy:PlotView Model="{Binding MonsterGradeModel}"
                                  Background="Transparent"/>
                </Border>

                <!-- 스킬 최대 데미지 수평 바차트 -->
                <Border Grid.Row="2" Grid.Column="0" Style="{StaticResource ChartCard}">
                    <oxy:PlotView Model="{Binding TopSkillsModel}"
                                  Background="Transparent"/>
                </Border>

                <!-- 몬스터 HP 수평 바차트 -->
                <Border Grid.Row="2" Grid.Column="2" Style="{StaticResource ChartCard}">
                    <oxy:PlotView Model="{Binding TopMonstersModel}"
                                  Background="Transparent"/>
                </Border>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
