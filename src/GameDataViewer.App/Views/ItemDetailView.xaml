<UserControl x:Class="GameDataViewer.App.Views.ItemDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="480" d:DesignWidth="260">

    <UserControl.Resources>
        <Style x:Key="PropLabel" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="Foreground" Value="{DynamicResource MahApps.Brushes.Gray3}"/>
        </Style>
        <Style x:Key="PropValue" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <!-- 빈 상태 -->
        <TextBlock x:Name="EmptyHint"
                   Text="아이템을 선택하세요"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   Opacity="0.4" FontSize="13" FontStyle="Italic"/>

        <!-- 상세 패널 -->
        <ScrollViewer x:Name="DetailPanel" Visibility="Collapsed"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="12,10">

                <!-- 등급 뱃지 + 이름 -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                    <Border CornerRadius="3" Padding="6,3" Margin="0,0,8,0"
                            VerticalAlignment="Center"
                            Background="{Binding Grade, Converter={StaticResource GradeToColor}}">
                        <TextBlock Text="{Binding Grade}" FontWeight="Bold" FontSize="11" Foreground="White"/>
                    </Border>
                    <TextBlock Text="{Binding Name}" FontSize="15" FontWeight="Bold" VerticalAlignment="Center"/>
                </StackPanel>

                <TextBlock Text="{Binding SubCategory}"
                           Opacity="0.5" FontSize="12" Margin="0,0,0,10"/>

                <Separator Margin="0,0,0,8"/>

                <!-- 스탯 Grid -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="72"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="26"/>
                        <RowDefinition Height="26"/>
                        <RowDefinition Height="26"/>
                        <RowDefinition Height="26"/>
                        <RowDefinition Height="26"/>
                        <RowDefinition Height="26"/>
                        <RowDefinition Height="26"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="분류" Style="{StaticResource PropLabel}"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Category}" Style="{StaticResource PropValue}"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="공격력" Style="{StaticResource PropLabel}"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding AttackPower, StringFormat={}{0:#,0}}" Style="{StaticResource PropValue}"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="방어력" Style="{StaticResource PropLabel}"/>
                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding DefensePower, StringFormat={}{0:#,0}}" Style="{StaticResource PropValue}"/>

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="마력" Style="{StaticResource PropLabel}"/>
                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding MagicPower, StringFormat={}{0:#,0}}" Style="{StaticResource PropValue}"/>

                    <TextBlock Grid.Row="4" Grid.Column="0" Text="필요 LV" Style="{StaticResource PropLabel}"/>
                    <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding RequiredLevel}" Style="{StaticResource PropValue}"/>

                    <TextBlock Grid.Row="5" Grid.Column="0" Text="교환" Style="{StaticResource PropLabel}"/>
                    <TextBlock Grid.Row="5" Grid.Column="1"
                               Text="{Binding IsTradable, Converter={StaticResource BoolToYesNo}}"
                               Style="{StaticResource PropValue}"/>

                    <TextBlock Grid.Row="6" Grid.Column="0" Text="가격" Style="{StaticResource PropLabel}"/>
                    <TextBlock Grid.Row="6" Grid.Column="1"
                               Text="{Binding Price, StringFormat={}{0:#,0} G}"
                               Style="{StaticResource PropValue}"/>
                </Grid>

                <Separator Margin="0,8"/>
                <TextBlock Text="설명" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <TextBlock Text="{Binding Description}" TextWrapping="Wrap"
                           Opacity="0.75" LineHeight="18"/>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
