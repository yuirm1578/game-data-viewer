<UserControl
    x:Class="GameDataViewer.App.Views.SettingsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:vm="clr-namespace:GameDataViewer.App.ViewModels"
    mc:Ignorable="d"
    d:DataContext="{d:DesignInstance Type=vm:SettingsViewModel}">

    <UserControl.Resources>
        <!-- 섹션 헤더 스타일 -->
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource MahApps.Brushes.Accent}"/>
            <Setter Property="Margin"     Value="0,18,0,6"/>
        </Style>

        <!-- 설정 카드 -->
        <Style x:Key="SettingsCard" TargetType="Border">
            <Setter Property="Background"      Value="{DynamicResource MahApps.Brushes.ThemeBackground}"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource MahApps.Brushes.Accent4}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius"    Value="4"/>
            <Setter Property="Padding"         Value="16,12"/>
            <Setter Property="Margin"          Value="0,0,0,4"/>
        </Style>

        <!-- 레이블 -->
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground"     Value="{DynamicResource MahApps.Brushes.ThemeForeground}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin"         Value="0,0,12,0"/>
            <Setter Property="MinWidth"       Value="140"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32,20,32,20" MaxWidth="640">

            <!-- ══════════════════════════════  일반  ══════════════════════════════ -->
            <TextBlock Text="일반" Style="{StaticResource SectionHeader}"/>
            <Border Style="{StaticResource SettingsCard}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- 기본 페이지 크기 -->
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="기본 페이지 크기" Style="{StaticResource FieldLabel}"
                               ToolTip="한 화면에 표시할 최대 데이터 행 수입니다. 값이 클수록 한번에 더 많은 데이터를 볼 수 있지만 초기 로딩이 느려질 수 있습니다. (10 ~ 500)"/>
                    <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Vertical">
                        <mah:NumericUpDown Value="{Binding DefaultPageSize}"
                                           Minimum="10" Maximum="500" Interval="10"
                                           StringFormat="0"
                                           Width="120" HorizontalAlignment="Left"/>
                        <TextBlock Text="한 탭에 표시할 데이터 행 수 (10 ~ 500, 기본 50)"
                                   FontSize="11"
                                   Foreground="{DynamicResource MahApps.Brushes.Accent4}"
                                   Margin="0,3,0,0"/>
                    </StackPanel>

                    <!-- 검색 디바운스 -->
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="검색 디바운스 (ms)" Style="{StaticResource FieldLabel}"
                               ToolTip="검색어를 입력하고 실제 검색이 시작되기까지 기다리는 시간(밀리초)입니다. 값이 작을수록 즉각 반응하지만 타이핑 중 불필요한 DB 조회가 늘어납니다. 최솟값 50ms."/>
                    <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Vertical">
                        <mah:NumericUpDown Value="{Binding SearchDebounceMs}"
                                           Minimum="50" Maximum="2000" Interval="50"
                                           StringFormat="0"
                                           Width="120" HorizontalAlignment="Left"/>
                        <TextBlock Text="검색 입력 후 DB 조회 대기 시간 (최솟값 50ms, 기본 300ms)"
                                   FontSize="11"
                                   Foreground="{DynamicResource MahApps.Brushes.Accent4}"
                                   Margin="0,3,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ══════════════════════════════  테마  ══════════════════════════════ -->
            <TextBlock Text="테마" Style="{StaticResource SectionHeader}"/>
            <Border Style="{StaticResource SettingsCard}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="앱 테마" Style="{StaticResource FieldLabel}"/>
                    <ComboBox ItemsSource="{Binding AvailableThemes}"
                              SelectedItem="{Binding Theme}"
                              MinWidth="160"
                              Style="{StaticResource MahApps.Styles.ComboBox}"/>
                    <TextBlock Text="(변경 즉시 미리보기, 저장 후 적용)"
                               Foreground="{DynamicResource MahApps.Brushes.Accent4}"
                               FontSize="11" VerticalAlignment="Center" Margin="10,0,0,0"/>
                </StackPanel>
            </Border>

            <!-- ══════════════════════════════  내보내기  ══════════════════════════ -->
            <TextBlock Text="내보내기" Style="{StaticResource SectionHeader}"/>
            <Border Style="{StaticResource SettingsCard}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="기본 저장 폴더" Style="{StaticResource FieldLabel}"/>
                    <TextBox Grid.Column="1"
                             Text="{Binding ExportDirectory, UpdateSourceTrigger=PropertyChanged}"
                             mah:TextBoxHelper.Watermark="비어있으면 문서 폴더 사용"
                             mah:TextBoxHelper.ClearTextButton="True"
                             Style="{StaticResource MahApps.Styles.TextBox}"
                             Margin="0,0,8,0"/>
                    <Button Grid.Column="2"
                            Content="📂 탐색"
                            Command="{Binding BrowseDirectoryCommand}"
                            Style="{StaticResource MahApps.Styles.Button.Square}"
                            MinWidth="70"/>
                </Grid>
            </Border>

            <!-- ══════════════════════════════  로깅  ══════════════════════════════ -->
            <TextBlock Text="디버그" Style="{StaticResource SectionHeader}"/>
            <Border Style="{StaticResource SettingsCard}">
                <CheckBox Content="디버그 로그 활성화 (다음 실행 시 적용)"
                          IsChecked="{Binding EnableDebugLogging}"
                          Style="{StaticResource MahApps.Styles.CheckBox}"/>
            </Border>

            <!-- ══════════════════════════════  저장 버튼  ══════════════════════════ -->
            <StackPanel Orientation="Horizontal" Margin="0,20,0,0" HorizontalAlignment="Right">
                <Button Content="↩ 기본값 복원"
                        Command="{Binding ResetCommand}"
                        Style="{StaticResource MahApps.Styles.Button.Square}"
                        Margin="0,0,8,0" MinWidth="130"/>
                <Button Content="💾 저장"
                        Command="{Binding SaveCommand}"
                        Style="{StaticResource MahApps.Styles.Button.Square.Accent}"
                        MinWidth="100"/>
            </StackPanel>

            <!-- 상태 메시지 -->
            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="{DynamicResource MahApps.Brushes.Accent}"
                       Margin="0,10,0,0"
                       FontSize="13"
                       HorizontalAlignment="Right"/>

        </StackPanel>
    </ScrollViewer>
</UserControl>
